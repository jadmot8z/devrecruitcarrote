{
  "rewrites": [
    {
      "source": "/pages/:page",
      "destination": "/pages/:page"
    },
    {
      "source": "/js/:file",
      "destination": "/js/:file"
    },
    {
      "source": "/css/:file",
      "destination": "/css/:file"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}